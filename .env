# ═══════════════════════════════════════════════════════════════════════════
# ⚙️  ENVIRONMENT CONFIGURATION - CROP CARE APPLICATION
# ═══════════════════════════════════════════════════════════════════════════

# 🗄️  DATABASE CONFIGURATION
# MongoDB connection string for crop_app database
MONGO_URI=mongodb://localhost:27017/crop_app

# 🔐 JWT SECURITY
# Secret key for signing JWT tokens - MUST be long and random for production
# Generated using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345_abcdefghijklmnopqrstuvwxyz_9876543210

# 📧 EMAIL CONFIGURATION (for future OTP via email)
# Currently OTP is printed in console for demo purpose
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# 📱 SMS CONFIGURATION (for future OTP via SMS using Twilio)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# 🌐 SERVER CONFIGURATION
PORT=5000
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════════
# ⚠️  SECURITY NOTES:
# 1. Never commit this file to GitHub - add .env to .gitignore
# 2. JWT_SECRET must be 32+ characters for production
# 3. Use different secrets for development, staging, and production
# 4. Rotate secrets periodically
# ═══════════════════════════════════════════════════════════════════════════
